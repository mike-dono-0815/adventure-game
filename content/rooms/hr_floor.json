{
  "id": "hr_floor",
  "name": "HR Floor",
  "background": "hr_floor",
  "walk_area": [
    [68, 610], [1278, 610], [1278, 760], [68, 760]
  ],
  "perspective": { "min_scale": 1.0, "max_scale": 1.1 },
  "entry_points": {
    "from_bobs_office": { "x": 100, "y": 690, "dir": "right" }
  },
  "trigger_zones": [
    {
      "id": "stakeholder_encounter",
      "rect": [68, 570, 650, 190],
      "once": true,
      "effects": [
        { "type": "lock_input" },
        { "type": "spawn_npc", "id": "stakeholder", "x": -80, "y": 680, "sprite": "stakeholder", "dualSheet": true, "dir": "right" },
        { "type": "parallel", "effects": [
          { "type": "walk_npc", "id": "stakeholder", "to_x": 560, "to_y": 680 },
          { "type": "walk_player", "to_x": 780, "to_y": 680 }
        ]},
        { "type": "set_player_dir", "dir": "left" },
        { "type": "wordfight", "intro_text": "What are you doing here?\nAre you even a real Amazonian?\nProve it — respond in the Amazon way,\nor I'll escort you out...", "intro_text_retry": "Oh. You again. You want to try this a second time?\nFine. Maybe you were just tired.\nLet's see if you actually know your Leadership Principles.", "retry_flag": "wordfight_lost", "on_loss_reset_trigger": "stakeholder_encounter", "on_loss_set_flag": "wordfight_lost", "on_loss_player_x": 780, "on_loss_player_y": 680 },
        { "type": "remove_npc", "id": "stakeholder" },
        { "type": "set_flag", "flag": "wordfight_won", "value": true },
        { "type": "walk_player", "to_x": 688, "to_y": 680 },
        { "type": "set_player_dir", "dir": "right" },
        { "type": "say", "text": "Phew. I can't believe that just worked. 'Disagree and Commit' came out of me like a reflex. I've been here too long. Or exactly long enough. Either way — Bob's office is right there.", "color": "player" },
        { "type": "unlock_input" }
      ]
    }
  ],
  "hotspots": [
    {
      "id": "door_to_bobs_office",
      "name": "Door to Bob's Office",
      "cursor": "exit",
      "rect": [0, 0, 138, 768],
      "walk_to": [150, 690],
      "face_dir": "left",
      "interactions": {
        "look_at": { "text": "The door to Bob's office." },
        "open": [
          {
            "condition": { "wordfight_won": true },
            "text": "You head into Bob's office.",
            "effects": [{ "type": "transition", "room": "bobs_office", "player_x": 980, "player_y": 758, "player_dir": "left" }]
          },
          { "text": "It's not the right moment to go in there." }
        ],
        "use": [
          {
            "condition": { "wordfight_won": true },
            "text": "You head into Bob's office.",
            "effects": [{ "type": "transition", "room": "bobs_office", "player_x": 980, "player_y": 758, "player_dir": "left" }]
          },
          { "text": "It's not the right moment to go in there." }
        ]
      }
    },
    {
      "id": "hr_open_office",
      "name": "open office",
      "rect": [144, 10, 943, 538],
      "walk_to": [688, 690],
      "interactions": {
        "look_at": {
          "text": "Spacious desks. Actual ergonomic chairs. A coffee machine that isn't broken. Plants — living ones. Someone has clearly negotiated well here. You find yourself wondering who exactly works up here, and whether they know what's happening on the floors below."
        },
        "use": { "text": "It's a nice office. I'm not going to use it." }
      }
    },
    {
      "id": "elevator_back",
      "name": "Elevator Door",
      "cursor": "exit",
      "rect": [1238, 0, 138, 768],
      "walk_to": [1200, 690],
      "face_dir": "right",
      "interactions": {
        "look_at": { "text": "The elevator back down to the office floors." },
        "open": {
          "text": "You take the elevator back down.",
          "effects": [{ "type": "transition", "room": "aisle", "player_x": 1040, "player_y": 700, "player_dir": "left" }]
        },
        "use": {
          "text": "You take the elevator back down.",
          "effects": [{ "type": "transition", "room": "aisle", "player_x": 1040, "player_y": 700, "player_dir": "left" }]
        }
      }
    }
  ]
}
