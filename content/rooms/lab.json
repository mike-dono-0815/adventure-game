  "hotspots": [
    {
      "id": "fifa_players",
      "name": "FIFA players",
      "rect": [515, 340, 439, 209],
      "walk_to": [450, 700],
      "face_dir": "right",
      "hidden_if": { "fifa_won": true },
      "dialogue": "fifa_players",
      "interactions": {
        "look_at": {
          "text": "Two people locked in a FIFA match with the focus of professional athletes. Neither has looked up since I entered. The score is 2-2. The tension is real."
        },
        "talk_to": [
          {
            "condition": { "fifa_challenged": false },
            "effects": [
              { "type": "say", "text": "Hi! I'd like to play a round.", "color": "player" },
              { "type": "set_flag", "flag": "fifa_challenged", "value": true },
              { "type": "dialogue", "dialogue": "fifa_players" }
            ]
          },
          {
            "effects": [
              { "type": "say", "text": "Hi! I'd like to do another round.", "color": "player" },
              { "type": "dialogue", "dialogue": "fifa_players" }
            ]
          }
        ],
        "pick_up": {
          "text": "They're not items. They're athletes."
        }
      }
    },
    {
      "id": "fifa_setup",
      "name": "FIFA setup",
      "rect": [649, 245, 267, 145],
      "walk_to": [782, 700],
      "face_dir": "back",
      "interactions": {
        "look_at": [
          {
            "condition": { "fifa_won": true },
            "text": "The FIFA screen shows the final score. Your win. It still feels slightly unreal."
          },
          {
            "text": "A large screen showing FIFA. Two controllers on the desk. Someone has taped a league table to the wall beside it. Chip's name is at the top in red marker. All other entries are crossed out."
          }
        ],
        "use": [
          {
            "condition": { "fifa_won": true },
            "text": "The game is over. I won. I don't need to play again."
          },
          {
            "condition": { "fifa_challenged": false },
            "effects": [
              { "type": "say", "text": "Hi! I'd like to play a round.", "color": "player" },
              { "type": "set_flag", "flag": "fifa_challenged", "value": true },
              { "type": "dialogue", "dialogue": "fifa_players" }
            ]
          },
          {
            "effects": [
              { "type": "say", "text": "Hi! I'd like to do another round.", "color": "player" },
              { "type": "dialogue", "dialogue": "fifa_players" }
            ]
          }
        ]
      }
    },
    {
      "id": "lab_whiteboard",
      "name": "whiteboard",
      "rect": [940, 181, 379, 196],
      "walk_to": [1152, 700],
      "face_dir": "right",
      "interactions": {
        "look_at": [
          {
            "condition": { "floor_digit_2_known": true },
            "text": "The whiteboard is covered in sprint velocity charts and a large org diagram. In the bottom corner: 'HR relocating to floor _8 — use new lift code'. You already noted the second digit."
          },
          {
            "condition": { "fifa_won": true },
            "text": "The whiteboard is dense with sprint velocity charts and a large org diagram that seems to have no top. At the bottom, in different handwriting: 'HR relocating to floor _8 — use new lift code'. Someone has wiped the first digit clean. But the second digit is clear: 8.",
            "effects": [
              { "type": "set_flag", "flag": "floor_digit_2_known", "value": true }
            ]
          },
          {
            "text": "I can't get to the whiteboard. The FIFA players are completely in the way."
          }
        ],
        "use": {
          "text": "I'm not writing on someone's sprint board."
        }
      }
    },
    {
      "id": "usb_stick",
      "name": "USB stick",
      "rect": [18, 459, 54, 18],
      "walk_to": [201, 700],
      "face_dir": "left",
      "hidden_if": { "has_item": "usb_stick" },
      "interactions": {
        "look_at": {
          "text": "A USB stick sitting next to a workstation, labelled in small type: 'CVNA BUILD v4.1 — FINAL_FINAL_v2'. Someone's entire project, just sitting there."
        },
        "pick_up": [
          {
            "condition": { "has_item": "usb_stick" },
            "text": "I already have the USB stick."
          },
          {
            "text": "You pick up the USB stick. It's lightweight. Potentially important. You pocket it.",
            "color": "narrator",
            "effects": [
              { "type": "add_item", "item": "usb_stick" },
              { "type": "remove_hotspot", "id": "usb_stick" }
            ]
          }
        ],
        "use": {
          "text": "I'd need a computer to use this."
        }
      }
    },
    {
      "id": "lab_computers",
      "name": "lab workstations",
      "rect": [64, 297, 275, 154],
      "walk_to": [201, 700],
      "face_dir": "left",
      "interactions": {
        "look_at": {
          "text": "Four workstations arranged in an L-shape. Only one is active, showing a terminal window mid-scroll. The others are sleeping. A sticky note on the active monitor reads: 'compile then go home'."
        },
        "use": {
          "text": "These aren't my machines."
        }
      }
    },
    {
      "id": "beanbag_area",
      "name": "beanbag",
      "rect": [475, 548, 605, 152],
      "walk_to": [848, 700],
      "face_dir": "right",
      "hidden_if": { "fifa_won": true },
      "interactions": {
        "look_at": {
          "text": "Two beanbags, the kind that appear in 'collaborative spaces' brochures and are usually used by nobody."
        },
        "use": {
          "text": "I'm not sitting in a beanbag right now. I have things to do."
        },
        "pick_up": {
          "text": "The beanbag is too large and too formless to carry."
        }
      }
    },
    {
      "id": "lab_mug",
      "name": "specimen cup",
      "rect": [1291, 415, 26, 28],
      "walk_to": [1152, 700],
      "face_dir": "right",
      "hidden_if": { "fifa_won": true },
      "interactions": {
        "look_at": [
          {
            "condition": { "fifa_won": true },
            "text": "A small plastic cup on the bench. There is something in it. It has a label. I am not going to read the label."
          },
          {
            "text": "I can't get to it. The FIFA players are completely in the way."
          }
        ],
        "pick_up": [
          {
            "condition": { "fifa_won": true },
            "text": "Absolutely not."
          },
          {
            "text": "I can't even get close. The FIFA players are blocking everything over there."
          }
        ],
        "use": [
          {
            "condition": { "fifa_won": true },
            "text": "I don't know what that is and I intend to keep it that way."
          },
          {
            "text": "I can't reach it. The FIFA players are in the way."
          }
        ]
      }
    },
    {
